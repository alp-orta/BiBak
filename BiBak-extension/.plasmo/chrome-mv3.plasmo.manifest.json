{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    }
  },
  "version": "1.0.0",
  "author": "Hackathon Team",
  "name": "DEV | BiBak",
  "description": "AI-powered product analysis",
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.com.tr/*",
        "https://*.trendyol.com/*",
        "https://*.hepsiburada.com/*"
      ],
      "js": [
        "static/contents/sidebar.tsx"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*"
  ]
}
